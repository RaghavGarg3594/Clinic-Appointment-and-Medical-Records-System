# ========================
# CAMRS Project .gitignore
# ========================

# --- Environment & Secrets ---
.env
.env.local
.env.*.local

# --- Java / Maven ---
camrs-backend/target/
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# --- Maven Wrapper ---
!.mvn/wrapper/maven-wrapper.jar
.mvn/

# --- Node / NPM ---
camrs-frontend/node_modules/
camrs-frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editor / IDE ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Python (leftover test files) ---
__pycache__/
.pytest_cache/
*.pyc

# --- Build Artifacts ---
maven.zip
*.zip

# --- Temp / Generated ---
/tmp/
camrs-pdfs/
*.bak
*.tmp
